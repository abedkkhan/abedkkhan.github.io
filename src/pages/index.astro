---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Research / papers / datasets — edit me any time
const research = [
  {
    title: 'Lost in Cultural Translation: Do LLMs Struggle with Math Across Cultural Contexts?',
    venue: 'arXiv, 2025',
    url: 'https://arxiv.org/abs/2503.18018',
    kind: 'arxiv',
  },
  {
    title: "Galton's Law of Mediocrity: Why Large Language Models Regress to the Mean and Fail at Creativity in Advertising",
    venue: 'arXiv, 2025',
    url: 'https://arxiv.org/abs/2509.25767',
    kind: 'arxiv',
  },
  {
    title: 'Document Search Engine',
    venue: 'IP Australia, 2025',
    url: 'https://ipsearch.ipaustralia.gov.au/patents/2025204710',
    kind: 'patent',
  },
  {
    title: 'GSM8K-cultural',
    venue: 'Hugging Face, 2025',
    url: 'https://huggingface.co/datasets/abedk/GSM8K-cultural',
    kind: 'dataset',
  },
];

const links = [
  { label: 'email', url: 'mailto:2019n06653@gmail.com' },
  { label: 'twitter', url: 'https://x.com/abidkarim813' },
  { label: 'linkedin', url: 'https://www.linkedin.com/in/abed-k-27a59aa0/' },
  { label: 'github', url: 'https://github.com/abedkkhan' },
];
---

<Base title="Abed K">
  <!-- Profile -->
  <section class="profile">
    <div class="nn-anim" aria-hidden="true">
      <svg viewBox="0 0 360 200" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <radialGradient id="node-glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#fbbf24" stop-opacity="0.9"/>
            <stop offset="60%" stop-color="#f59e0b" stop-opacity="0.35"/>
            <stop offset="100%" stop-color="#f59e0b" stop-opacity="0"/>
          </radialGradient>
          <linearGradient id="edge-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#f59e0b" stop-opacity="0"/>
            <stop offset="50%" stop-color="#f59e0b" stop-opacity="0.45"/>
            <stop offset="100%" stop-color="#f59e0b" stop-opacity="0"/>
          </linearGradient>
        </defs>

        <!-- edges: input(4) x=60  -> hidden(6) x=180 -> output(3) x=300 -->
        <g class="nn-edges" stroke="#3a2d10" stroke-width="0.8" fill="none">
          <!-- input -> hidden -->
          <line x1="60" y1="40"  x2="180" y2="20"/>
          <line x1="60" y1="40"  x2="180" y2="56"/>
          <line x1="60" y1="40"  x2="180" y2="92"/>
          <line x1="60" y1="40"  x2="180" y2="128"/>
          <line x1="60" y1="40"  x2="180" y2="164"/>
          <line x1="60" y1="40"  x2="180" y2="180"/>

          <line x1="60" y1="80"  x2="180" y2="20"/>
          <line x1="60" y1="80"  x2="180" y2="56"/>
          <line x1="60" y1="80"  x2="180" y2="92"/>
          <line x1="60" y1="80"  x2="180" y2="128"/>
          <line x1="60" y1="80"  x2="180" y2="164"/>
          <line x1="60" y1="80"  x2="180" y2="180"/>

          <line x1="60" y1="120" x2="180" y2="20"/>
          <line x1="60" y1="120" x2="180" y2="56"/>
          <line x1="60" y1="120" x2="180" y2="92"/>
          <line x1="60" y1="120" x2="180" y2="128"/>
          <line x1="60" y1="120" x2="180" y2="164"/>
          <line x1="60" y1="120" x2="180" y2="180"/>

          <line x1="60" y1="160" x2="180" y2="20"/>
          <line x1="60" y1="160" x2="180" y2="56"/>
          <line x1="60" y1="160" x2="180" y2="92"/>
          <line x1="60" y1="160" x2="180" y2="128"/>
          <line x1="60" y1="160" x2="180" y2="164"/>
          <line x1="60" y1="160" x2="180" y2="180"/>

          <!-- hidden -> output -->
          <line x1="180" y1="20"  x2="300" y2="60"/>
          <line x1="180" y1="20"  x2="300" y2="100"/>
          <line x1="180" y1="20"  x2="300" y2="140"/>

          <line x1="180" y1="56"  x2="300" y2="60"/>
          <line x1="180" y1="56"  x2="300" y2="100"/>
          <line x1="180" y1="56"  x2="300" y2="140"/>

          <line x1="180" y1="92"  x2="300" y2="60"/>
          <line x1="180" y1="92"  x2="300" y2="100"/>
          <line x1="180" y1="92"  x2="300" y2="140"/>

          <line x1="180" y1="128" x2="300" y2="60"/>
          <line x1="180" y1="128" x2="300" y2="100"/>
          <line x1="180" y1="128" x2="300" y2="140"/>

          <line x1="180" y1="164" x2="300" y2="60"/>
          <line x1="180" y1="164" x2="300" y2="100"/>
          <line x1="180" y1="164" x2="300" y2="140"/>

          <line x1="180" y1="180" x2="300" y2="60"/>
          <line x1="180" y1="180" x2="300" y2="100"/>
          <line x1="180" y1="180" x2="300" y2="140"/>
        </g>

        <!-- signal pulses: traveling dots that sweep left->right -->
        <g class="nn-pulses">
          <circle class="pulse p1" r="2.2" fill="#fbbf24"/>
          <circle class="pulse p2" r="2.2" fill="#fbbf24"/>
          <circle class="pulse p3" r="2.2" fill="#fbbf24"/>
          <circle class="pulse p4" r="2.2" fill="#fbbf24"/>
          <circle class="pulse p5" r="2.2" fill="#fbbf24"/>
        </g>

        <!-- nodes -->
        <g class="nn-nodes">
          <!-- input layer -->
          <circle class="node n-in"  cx="60"  cy="40"  r="6"/>
          <circle class="node n-in"  cx="60"  cy="80"  r="6"/>
          <circle class="node n-in"  cx="60"  cy="120" r="6"/>
          <circle class="node n-in"  cx="60"  cy="160" r="6"/>
          <!-- hidden layer -->
          <circle class="node n-hid" cx="180" cy="20"  r="6"/>
          <circle class="node n-hid" cx="180" cy="56"  r="6"/>
          <circle class="node n-hid" cx="180" cy="92"  r="6"/>
          <circle class="node n-hid" cx="180" cy="128" r="6"/>
          <circle class="node n-hid" cx="180" cy="164" r="6"/>
          <circle class="node n-hid" cx="180" cy="180" r="6"/>
          <!-- output layer -->
          <circle class="node n-out" cx="300" cy="60"  r="6"/>
          <circle class="node n-out" cx="300" cy="100" r="6"/>
          <circle class="node n-out" cx="300" cy="140" r="6"/>
        </g>
      </svg>
    </div>
    <h1>Abed K</h1>
  </section>

  <!-- About -->
  <section class="section">
    <div class="section-head">about</div>
    <div class="section-body about">
      <p>
        Hey, my name is Abed. I&apos;m an AI research engineer at
        <strong>55mV Research Lab</strong>.
      </p>
      <p>
        These days I work mostly on RL for LLMs: SFT, LoRA, GRPO,
        RLHF, the alphabet soup. Currently trying to make LLMs more creative
        in advertising and media, which means designing reward signals,
        building fairly complex RL environments, putting together evaluation
        pipelines, and playing with steering vectors. And because none of
        this works without good data, a lot of my time also goes into
        synthetic dataset generation, for training and for eval.
      </p>
      <p>
        On the side, I&apos;m digging into linear probes and sparse
        autoencoders (SAEs), experimenting with them, trying to actually see
        what&apos;s happening inside these models. Hoping to contribute to
        mech interp soon.
      </p>
    </div>
  </section>

  <!-- Links -->
  <section class="section">
    <div class="section-head">links</div>
    <div class="section-body">
      <div class="links-row">
        {links.map((l) => (
          <a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Research -->
  <section class="section">
    <div class="section-head">research &amp; artifacts</div>
    <div class="section-body">
      <ul class="item-list">
        {research.map((r) => (
          <li>
            <a class="item" href={r.url} target="_blank" rel="noopener noreferrer">
              <div class="item-title">{r.title}</div>
              <div class="item-meta">
                <span class={`tag ${r.kind}`}>{r.kind}</span>
                <span>{r.venue}</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Blogs -->
  <section class="section">
    <div class="section-head">blogs · {posts.length} posts</div>
    <div class="section-body">
      {posts.length === 0 ? (
        <p style="color: var(--fg-dimmer); font-size: 13px; margin: 0;">
          No posts yet. Drop markdown files into <code>src/content/blog/</code> and they'll appear here.
        </p>
      ) : (
        <ul class="item-list">
          {posts.map((p) => (
            <li>
              <a class="item" href={`/blog/${p.slug}/`}>
                <div class="item-title">{p.data.title}</div>
                <div class="item-meta">
                  <span>{fmtDate(p.data.pubDate)}</span>
                  {p.data.readTime && <span>· {p.data.readTime}</span>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Base>
